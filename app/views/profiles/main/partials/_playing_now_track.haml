%h4 Playing now:

.separator.sep_10.sep_default

- if profile_playing_now_track.present?

  .media-left.mid_align
    = image_tag profile_playing_now_track.artist.artist_image, class: 'img_50 img_rnd'

  .media-body.mid_align

    %h4
      %strong
        = link_to profile_playing_now_track.title, '#'
    %h5
      = link_to profile_playing_now_track.artist.name, artist_path(name: profile_playing_now_track.artist.artist_name)

- else

  Nothing is playing now.
