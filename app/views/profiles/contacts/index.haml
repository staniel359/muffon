#contacts_page.panel.center

  .panel_header

    .panel_header_left

      %h3
        %i.fas.fa-address-book
        Contacts

    .panel_header_right

      .media-left
        %h4
          = link_to @profile.nickname, profile_path
      .media-right
        = link_to profile_path do
          = image_tag @profile.avatar.url(:sm), class: 'img_rnd img_30'

  .separator.sep_0.sep_light

  #contacts_page_followers.panel_content

    %h4
      = link_to "Followers (#{@followers.count})", profiles_followers_path

    .separator.sep_10.sep_default

    - if @followers.any? 
      %table.table.table-hover
        = render partial: 'profiles/profile', collection: @followers, profile: @follower
    - else
      = (current_profile?(@profile) ? "You don't" : "#{@profile.nickname} doesn't") + ' have any followers yet.'

  #contacts_page_following.panel_content

    %h4
      = link_to "Following (#{@following.count})", profiles_following_path

    .separator.sep_10.sep_default

    - if @following.any? 
      %table.table.table-hover
        = render partial: 'profiles/profile', collection: @following, profile: @follower
    - else
      = (current_profile?(@profile) ? "You aren't" : "#{@profile.nickname} isn't") + ' following anybody.'
