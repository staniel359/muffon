$('#playlist-tracks').html("<%= j render 'profiles/playlists/tracks' %>")
$('#playlist-play-action').html("<%= j render 'profiles/playlists/play_btn' %>")
$("#playlist-add-artist-btn_<%= @artist.artist_id %>").html(
  "<%= j render 'profiles/playlists/artist/add_btn', artist_id: @artist.id, in_playlist: false %>"
);
<% @artist.profile_tracks.each do |track| %>
  $("*#playlist-add-track-btn_<%= track.track_id %>").html(
    "<%= j render 'profiles/playlists/track/add_btn', track_id: track.id, in_playlist: false %>"
  );
<% end %>
