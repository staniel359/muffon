- if @tracks.any?
  - first_track = @tracks.first.decorate
  = button_to player_play_path(artist_name: first_track.artist_name, track_title: first_track.title, source: 'playlist', source_id: @playlist.id), class: 'btn btn-primary btn-sm', method: :get, remote: true do
    %i.fas.fa-play
    Play
