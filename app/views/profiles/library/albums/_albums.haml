.d-flex.justify-content-between.align-items-center
  %h5.mb-0
    = "Albums (#{@profile.albums_count}):"
  #albums-order-scope.d-flex
    .mr-3
      = render 'order'
    = render 'scope'

.separator.default.my-2

- if @albums.any?
  .row
    - @albums.decorate.each do |album|
      .col-6.col-sm-4.col-md-3
        = render 'album', album: album
  = paginate @albums
- else
  There are no albums.
