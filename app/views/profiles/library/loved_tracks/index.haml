.card
  .card-body
    = render 'profiles/library/panel_header'

    %h5
      %i.fas-fa-heart
      = "Loved tracks (#{@profile.loved_tracks_count}):"

    .separator.default.my-2

    - if @loved_tracks.any?
      %table.table.table-hover.table-sm
        = render partial: 'loved_track', collection: @loved_tracks.decorate

      = paginate @loved_tracks
    - else
      There are no loved tracks.
