%h5
  = link_to "Plays (#{@profile.plays_count}):", profiles_library_plays_path

.separator.default.my-2

- if @plays.any?
  %table.table.table-hover.table-sm
    = render partial: 'profiles/library/plays/play', collection: @plays

  - if @profile.plays_count > 10
    .text-right
      = link_to "View more...", profiles_library_plays_path, class: 'btn btn-primary btn-sm'

- else
  There are no plays.
