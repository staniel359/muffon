.card
  .card-body
    = render 'profiles/library/panel_header'

    = render 'panel_header'

    %h5
      = "Artists (#{@profile_tag.artist_taggings_count}):"

    .separator.default.my-2

    - if @artist_taggings.any?
      %table.table.table-hover.table-sm.mb-2
        - @artist_taggings.decorate.each do |artist|
          = render 'artist'
      = paginate @artist_taggings
    - else
      There are no taggings.
