<% if @tracks.any? || @artists.any? || @albums.any? %>
  $('#library_panel').hide()
  $('#library_search_results').show().html("<%= j render 'search_results' %>")
<% elsif params[:q].present? %>
  $('#library_panel').hide()
  $('#library_search_results').show().html("Nothing was found.")
<% else %>
  $('#library_search_results').hide()
  $('#library_panel').show()
<% end %>
$('#loading').hide()
$('[data-toggle="tooltip"]').tooltip({trigger: 'hover'});