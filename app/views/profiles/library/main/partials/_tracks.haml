- if @tracks.any?

  %table.table.table-hover.table-condensed
    = render partial: 'profiles/library/main/partials/track', collection: @tracks

  - unless params[:action] == 'tracks'

    .text_right.mg_top_10
      = link_to 'View more...', profiles_library_tracks_path(scope: params[:scope]), class: 'btn btn-primary btn-sm'

- else

  = (current_profile?(@profile) ? "You haven't" : "#{@profile.nickname} hasn't") + ' listened to any tracks during that period.'