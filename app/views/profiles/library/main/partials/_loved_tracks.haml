- if @loved_tracks.any?

  %table.table.table-hover.table-condensed
    = render partial: 'profiles/library/main/partials/loved_track', collection: @loved_tracks

  - unless params[:action] == 'tracks'

    .text_right.mg_top_10
      = link_to 'View more...', profiles_library_tracks_path(show: 'loved'), class: 'btn btn-primary btn-sm'

- else

  = (current_profile?(@profile) ? 'You don\'t have' : "#{@profile.nickname} doesn't have") + ' any loved tracks yet.'