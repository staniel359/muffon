<% if params[:collection] == 'artists' %>
  $('#library_top_artists_scope').html(
    "<%= j render 'profiles/library/main/scope/library_artists' %>"
  )
  $('#library_top_artists').html(
    "<%= j render 'profiles/library/main/partials/artists' %>"
  )
<% elsif params[:collection] == 'albums' %>
  $('#library_top_albums_scope').html(
    "<%= j render 'profiles/library/main/scope/library_albums' %>"
  )
  $('#library_top_albums').html(
    "<%= j render 'profiles/library/main/partials/albums' %>"
  )
<% elsif params[:collection] == 'tracks' %>
  $('#library_top_tracks_scope').html(
    "<%= j render 'profiles/library/main/scope/library_tracks' %>"
  )
  $('#library_top_tracks').html(
    "<%= j render 'profiles/library/main/partials/tracks' %>"
  )
<% end %>

$('.dropdown.open .dropdown-toggle').dropdown('toggle')