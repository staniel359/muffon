$('#top_tracks').html("<%= j render 'profiles/library/main/partials/tracks' %>")
$('#tracks_paginate').html("<%= j paginate @tracks %>")

$('#top_tracks_scope').html("<%= j render 'profiles/library/main/scope/tracks' %>")
$('#top_tracks_order').html("<%= j render 'profiles/library/main/order/tracks' %>")

$('.dropdown.open .dropdown-toggle').dropdown('toggle')

url = "<%= library_tracks_path(order: params[:order], page: params[:page], scope: params[:scope]) %>".replace('amp;', '')
window.history.pushState({turbolinks: true, url: url}, '', url)