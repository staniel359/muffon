.row.text-center.scrollspy
  .col-5.col-sm-12
    = link_to artist_path(@artist.name) do
      .mb-2
        = image_tag @artist.image, class: 'rounded-circle img-fluid'
      %h5.mb-0
        %strong
          = @artist.name
      %h6 on muffon

    %hr.my-2.d-none.d-sm-block

  .col-7.col-sm-12#profile-artist-data
    %h6.mb-0
      In your library since
    %h6
      %strong
        = @artist.created_at.strftime('%e %b %Y')

    - if @taggings.any?
      %hr.my-2

      %h6.mb-1
        Your tags:
      - @taggings.decorate.each do |tagging|
        = link_to profiles_library_tagging_path(tag_name: tagging.tag_name), class: 'tag' do
          %strong
            = tagging.tag_name

%hr.my-3.d-sm-none
