%tr
  %td{id: "track_#{track.track.id}", class: ('list_playing_now_track' if playing_now_track_id == track.track.id)}

    .media-left.list_play_button

      - if playing_now_track_id == track.track.id
        = render 'player/list_play_button'
      - else
        = button_to play_path(artist: track.artist.artist_name, track: track.track.track_title), remote: true, class: 'btn btn-primary btn-sm play_btn', method: :get, onclick: 'loadTrack(this)' do
          %i.fas.fa-play

    .media-body

      .track_options

        = render 'muffon/track_dropdown', track: track.track

      %h5
        - if track.loved?
          %i.fas.fa-heart{style: 'color:red'}
        - else
          %i.far.fa-heart
        %strong
          = link_to track.track.title, library_artist_track_path(title: track.track.track_title)

      %h5
        = link_to pluralize(track.playcount, 'play'), library_artist_track_plays_path(name: track.artist.artist_name, title: track.track.track_title)

    %iframe.mg_top_10{frameborder:'0', width: 480, height: 270, hidden: true}
