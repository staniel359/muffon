.card
  .card-body
    = render 'profiles/library/artists/panel_header'

    %h5
      = "Albums (#{@artist.albums_count}):"

    .separator.default.my-2

    - if @albums.any?
      .row
        - @albums.decorate.each do |album|
          .col-6.col-sm-4.col-lg-3.mb-2
            = render 'album', album: album
      = paginate @albums
    - else
      There are no albums.
