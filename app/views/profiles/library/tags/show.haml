.card
  .card-body
    = render 'profiles/library/panel_header'

    %h5.d-inline.mr-2
      %i.fas.fa-tag
      Tags:
    .d-inline
      = link_to tag_path(tag_name: @tag.name), class: 'tag' do
        %strong
          = @tag.name

    .separator.default.my-2

    - if @artists.present?
      %table.table.table-hover.table-sm
        - @artists.decorate.each do |artist|
          %tr
            %td.media.align-items-center
              .mr-2
                = image_tag artist.image, class: 'img-sm rounded-circle'
              .media-body
                %h5.mb-1
                  = link_to artist.name, profiles_library_artist_path(artist_name: artist.name)
      = paginate @artists
