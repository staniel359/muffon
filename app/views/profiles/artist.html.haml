.library_artist_page_panel.panel.panel-default.profile_library.center
	.panel_header
		%h3= "#{@artist.artist.name} in #{@profile.nickname}'s library"
	.library_artist_page.panel_wider_content
		.library_artist_page_left.media-left
			= render partial: 'profile_artist', locals: {profile_artist: @artist}
		.library_artist_page_right.media-body
			.library_artist_page_tracks_panel
				.panel_header_sm
					%h4= link_to pluralize(@artist.profile_tracks.count, 'tracks'), library_artist_tracks_path(@profile)
				.library_artist_page_tracks
					%table.table.table-hover.table-condensed
						= render partial: 'profile_track', collection: @tracks
					.view_more
						%h5= link_to 'View more...', library_artist_tracks_path(@profile) if @artist.profile_tracks.count > 5
			%hr
			.library_artist_page_albums_panel
				.panel_header_sm
					%h4= link_to "#{@artist.profile_albums.count} albums", library_artist_albums_path(@profile)
				.library_artist_page_albums.panel_wider_content
					= render partial: 'profile_album', collection: @albums
					.view_more
						%h5= link_to 'View more...', library_artist_albums_path(@profile) if @artist.profile_albums.count > 3
			%hr
			.library_artist_page_plays_panel
				.panel_header_sm
					%h4= link_to pluralize(@artist.count, 'play'), library_artist_plays_path(@profile)
				.library_artist_page_plays
					%table.table.table-hover.table-condensed
						= render partial: 'profile_play', collection: @plays
					.view_more
						%h5= link_to 'View more...', library_artist_plays_path(@profile) if @artist.plays.count > 5