- @common_artists.first(5).each do |artist|
  = link_to profiles_library_artist_path(artist_name: artist.name) do
    .media.align-items-center.my-2
      .mr-2
        = image_tag artist.image, class: 'img-xs rounded-circle'
      .media-body
        %h6.mb-0
          %strong
            = artist.name
        .small
          = pluralize(artist.plays_count, 'play')

- if @common_artists.count > 5
  .text-right
    = link_to "and #{@common_artists.count - 5} more...", '#'
