%tr.profile
	%td
		.media-left.mid_align
			= link_to profile do
				= image_tag profile.avatar.url(:sm), class: 'img_rnd'
		.media-body.mid_align
			%h4.inline.mg_btm_5= link_to profile.nickname, profile
			- if current_profile?(profile)
				%h5.inline (that's you)
			- if logged_in? && !current_profile?(profile)
				%br
				.inline#follow_button{id: profile.id}
					= render 'relationships/follow_button', profile: profile
				.inline
					= link_to 'Write a message', new_message_path(to: profile), class: 'btn btn-sm btn-primary'