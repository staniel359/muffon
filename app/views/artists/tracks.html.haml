.artist_tracks_page.panel.panel-default.center
	.panel_header
		%h3
			= link_to @tracks.first['artist']['name'], artist_path
			tracks
	%hr
	.artist_tracks_page_tracks.panel_content
		%table.table.table-hover.table-condensed
			= render partial: 'track', collection: @tracks, locals: {artist_name: @tracks.first['artist']['name']}