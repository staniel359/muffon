#artist_wiki_page.artist_page.panel.center
  
  = render 'panel_header'

  .separator.sep_0.sep_light

  .panel_content

    %h4
      %i.fas.fa-info-circle
      Wiki:

    .separator.sep_10.sep_default

    %h5
      - if @artist.description.present?

        = @artist.artist_description

      - else

        .text-muted
          No description.
