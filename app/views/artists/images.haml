#artist_images_page.artist_page.panel.center

  = render 'panel_header'

  .separator.sep_0.sep_light

  .panel_content

    %h4
      %i.fas.fa-images
      Images:

    .separator.sep_10.sep_default

    .panel_content_wide

      - @images.map do |image|

        .image.image_170.inline.mg_btm_20
          = image_tag image, onclick: "$('#image_modal_#{image.split('/').last}').modal()", style: 'cursor: pointer'

        #image_modal.modal{id: image.split('/').last}
          .modal-dialog.text_center
            = image_tag image.gsub('/avatar170s', ''), style: 'max-width:600px'

    .text_center
      .btn-group
        = link_to_prev_page @images, '< Previous', class: 'btn btn-primary group_btn'
        = link_to_next_page @images, 'Next >', class: 'btn btn-primary group_btn' unless @images.length < 40
