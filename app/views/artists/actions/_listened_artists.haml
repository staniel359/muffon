- if listened
  .listened-action-btn.light
    = button_to listened_artist_path(artist_id: artist.id), method: :delete, remote: true, data: {toggle: 'tooltip', placement: 'bottom'}, title: "Listened", class: 'action-btn' do
      %i.fas.fa-check
- else
  .listened-action-btn
    = button_to listened_artists_path(artist_id: artist.id), remote: true, data: {toggle: 'tooltip', placement: 'bottom'}, title: "Mark as listened", class: 'action-btn' do
      %i.fas.fa-check
