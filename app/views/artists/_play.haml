%tr
  %td{id: "track_#{play.track.id}", class: ('list_playing_now_track' if playing_now_track_id == play.track.id)}

    .media-left

      .list_play_button.play_button
        - if playing_now_track_id == play.track.id
          = render 'player/list_play_button'
        - else
          = button_to play_path(artist: play.artist.artist_name, track: play.track.track_title), remote: true, class: 'btn btn-primary btn-sm play_btn', method: :get, onclick: 'loadTrack(this)' do
            = fa_icon 'play'

      = image_tag (play.album.present? ? play.album.album_cover : 'missing_album.png'), class: 'img_50'

    .media-body

      .track_options

        .created_at
          %h6
            = l play.created_at, format: "%e %b %Y"
          %h6
            = l play.created_at, format: "%H:%M"

        = render 'shared/track_dropdown', track: play.track

      %h5
        - if play.profile_track.loved?
          = fa_icon 'heart', style: 'color: red'
        - else
          = fa_icon 'heart-o'
        %strong
          = link_to play.track.title, library_artist_track_path(id: play.profile_id, name: play.artist.artist_name, title: play.track.track_title)

      %h5
        = link_to play.artist.name, library_artist_path(id: play.profile_id, name: play.artist.artist_name)

      - if play.album.present?
        %h5
          = link_to play.album.title, library_artist_album_path(id: play.profile_id, name: play.artist.artist_name, title: play.album.album_title), class: 'text-muted'
