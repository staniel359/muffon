#album-play-btn-main
  = button_to player_play_path, class: 'btn btn-light btn-sm', method: :get, remote: true do
    %i.fas.fa-play.mr-1
    Play album

.mobile-centered
  #album-title-main
    %h4
      = @album.title
    %h5.mb-1
      = link_to @artist.name, @artist
    %h6.mb-2.text-muted
      = @album.release_date

= render 'lastfm_listeners_plays'
= render 'labels'
= render 'tags'

= render 'description'

%hr.my-3

= render 'muffon_listeners_plays'
