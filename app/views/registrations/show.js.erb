$('#signup-form').html("<%= j render 'signup_form' %>");
$('#signup-form').prependTo($('#start-wrap'))
$('#start').hide("slide", { direction: 'left' }, 500)
$('#signup-btns').hide(
  "slide", { direction: 'left' }, 500, function() {
    $('#signup-btns').removeClass('d-block')
  }
)
$('#signup-form').show("slide", { direction: 'right' }, 500)
$('.ui-effects-placeholder').last().hide();
window.history.pushState(null , null, 'signup')
