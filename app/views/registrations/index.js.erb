$('#signup-btns').html("<%= j render 'signup_btns_card' %>");
$('#signup-btns').prependTo($('#start-wrap'))
$('#login-form').hide(
  "slide", { direction: 'left' }, 500, function() {
    $('#login-form').removeClass('d-block')
  }
)
$('#signup-btns').show("slide", { direction: 'right' }, 500)
$('.ui-effects-placeholder').last().hide();
window.history.pushState(null , null, 'signup')
