$('#artists').html("<%= j render 'library/partials/artists' %>")
$('#artists_paginate').html("<%= j paginate @artists, params: { action: 'artists' } %>")
$('#artists_scope').html("<%= j render 'library/partials/order_label' %>")
$('.dropdown.open .dropdown-toggle').dropdown('toggle')

url = "<%= '?order=' + params[:order]%><%= '&page=' + params[:page] if params[:page] %>".replace('amp;', '')
window.history.pushState({turbolinks: true, url: url}, '', url)