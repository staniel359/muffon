%tr
  %td{id: "track_#{new_track.track.id}", class: ('list_playing_now_track' if playing_now_track&.id == new_track.track.id)}
    .media-left
      .list_play_button.play_button
        = render 'player/get_track_button', track: new_track.track
      = image_tag new_track.artist.artist_image, class: 'img_50'
    .media-body
      .pull-right.mg_top_10
        = button_to send_to_queue_path(track_ids: [new_track.track.id]), class: 'btn btn-primary btn-sm play_btn', method: :get, remote: true do
          = fa_icon 'arrow-right'
      .created_at.pull-right
        %h5
          = l new_track.created_at, format: "%e %b %Y"
        %h5.pull-right
          = l new_track.created_at, format: "%H:%M"
      %h5
        - if new_track.loved?
          = fa_icon 'heart', style: 'color:red'
        - else
          = fa_icon 'heart-o'
        %strong
          = link_to new_track.track.title, library_artist_track_path(name: new_track.artist.artist_name, title: new_track.track.track_title)
      %h5
        = link_to new_track.artist.name, library_artist_path(id: @profile.id, name: new_track.artist.artist_name)
      %h5
        = link_to library_artist_track_plays_path(name: new_track.artist.artist_name, title: new_track.track.track_title) do
          = pluralize(new_track.playcount, 'play')
