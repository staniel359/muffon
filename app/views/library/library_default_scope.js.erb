<% if params[:artists_default_scope] %>
	<% get_scoped_artists(params[:artists_default_scope].to_i) %>
	$('#top_artists').html("<%= j render partial: 'profile_artist', collection: @top_artists %>")
	$('#top_artists_default_scope').html("<%= j render partial: 'artists_time_scope_label', locals: {message: 'Default scope:'} %>")
	$('#top_artists_scope').html("<%= j render partial: 'artists_time_scope_label', locals: {message: 'Show by a period:'} %>")
<% elsif params[:albums_default_scope] %>
	<% get_scoped_albums(params[:albums_default_scope].to_i) %>
	$('#top_albums').html("<%= j render partial: 'profile_album', collection: @top_albums %>")
	$('#top_albums_scope').html("<%= j render partial: 'albums_time_scope_label', locals: {message: 'Show by a period:'} %>")
	$('#top_albums_default_scope').html("<%= j render partial: 'albums_time_scope_label', locals: {message: 'Default scope:'} %>")
<% elsif params[:tracks_default_scope] %>
	<% get_scoped_tracks(params[:tracks_default_scope].to_i) %>
	$('#top_tracks').html("<%= j render partial: 'profile_track', collection: @top_tracks %>")
	$('#top_tracks_scope').html("<%= j render partial: 'tracks_time_scope_label', locals: {message: 'Show by a period:'} %>")
	$('#top_tracks_default_scope').html("<%= j render partial: 'tracks_time_scope_label', locals: {message: 'Default scope:'} %>")
<% end %>