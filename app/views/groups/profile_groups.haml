#profile_groups.panel.center
  .panel_header
    %h3.inline
      = @title

  .separator.sep_0.sep_light
  
  .panel_content

    - if @groups.any?

      %table.table.table-hover-table-condensed
        = render @groups
          
    - else
      = (current_profile?(@profile) ? "You haven't" : "#{@profile.nickname} hasn't") + ' joined any groups yet.'