.card
  .card-body
    = render 'partials/profiles/library/panel_header'

    .separator.default.mt-2.mb-3

    %h5
      = "Plays (#{@profile.plays_count}):"

    .separator.default.my-2

    - if @plays.any?
      %table.table.table-hover.table-sm
        = render partial: 'partials/profiles/library/instances/play', collection: @plays.decorate
      = pagination
    - else
      There are no plays.
