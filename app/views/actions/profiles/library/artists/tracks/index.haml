.card
  .card-body
    = render 'partials/profiles/library/artists/panel_header'

    %h5
      = "Tracks (#{@artist.tracks_count}):"

    .separator.default.my-2

    - if @tracks.any?
      %table.table.table-hover.table-sm
        = render partial: 'partials/profiles/library/instances/artist/track', collection: @tracks.decorate
      = pagination
    - else
      There are no tracks.
