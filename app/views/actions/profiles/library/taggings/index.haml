#library_tags_panel.panel.library_page.center
  
  = render 'library/partials/panel_header'

  .separator.sep_0.sep_light

  #library_tags_panel_content.panel_content

    %h4 Taggings:

    .separator.sep_10.sep_default

    - if @taggings.any?

      %table.table.table-condensed

        %thead
          %tr
            %th
            %th 
              %i.fas.fa-user
              Artists
            %th
              %i.fas.fa-dot-circle
              Albums
            %th
              %i.fas.fa-music
              Tracks

        %tbody

          - @taggings.map do |tagging|
            %tr
              %td
                = link_to library_tagging_path(name: tagging.tag.name), class: 'btn btn-primary btn-sm' do
                  %strong
                    = tagging.tag.name
              %td
                %h4
                  = link_to tagging.artist_taggings_count, library_artists_tagging_path(name: tagging.tag.name), class: 'mid_align' if tagging.artist_taggings_count.positive?
              %td
                %h4.mid_align
                  = link_to tagging.album_taggings_count, library_albums_tagging_path(name: tagging.tag.name), class: 'mid_align' if tagging.album_taggings_count.positive?
              %td
                %h4.mid_align
                  = link_to tagging.track_taggings_count, library_tracks_tagging_path(name: tagging.tag.name), class: 'mid_align' if tagging.track_taggings_count.positive?

      .text_center.mg_top_10
        = paginate @taggings

    - else

      %h4
        - if current_profile?(@profile)
          You haven't
        - else
          = @profile.nickname
          hasn't
        tagged anything with this tag.
