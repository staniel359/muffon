.card
  .card-body
    = render 'partials/profiles/library/panel_header'

    %h5
      %i.fas.fa-tag
      Tags:

    .separator.default.my-2
    
    - if @tags.any?
      .mb-2
        - @tags.each do |tag|
          = link_to profiles_library_tag_path(tag_name: tag[0]), class: 'tag' do
            %strong
              = tag[0]
            %small
              = "(#{tag[1]})"
    - else
      There are no tags.
