.card
  .card-body
    .d-flex.align-items-center.justify-content-between
      %h4
        %i.fas.fa-list-ul
        Playlists
      .media
        .mr-2
          = image_tag @profile.avatar.url(:xs), class: 'rounded-circle'
        .media-body
          %h5
            = link_to @profile.nickname, @profile

    %hr.my-2

    .d-flex.justify-content-between.align-items-center

      #playlist-name-play-action.d-flex.align-items-center
        %h1.font-light.ml-3.mr-3.mb-0
          = @playlist.name
        #playlist-play-action
          = render 'partials/profiles/playlists/play_btn'

      #playlist-profile-actions
        - if current_profile?(@profile)
          = render 'partials/profiles/playlists/dropdown'

    .separator.default.my-2
    
    #playlist-tracks
      = render 'partials/profiles/playlists/tracks'

= render 'modals/playlists/search'
