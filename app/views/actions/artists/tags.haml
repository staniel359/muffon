.card
  .card-body
    = render 'partials/artists/panel_header'

    %h5
      %i.fas.fa-tags
      Tags:

    .separator.default.my-2

    - @tags.each do |tag|
      = link_to tag_path(tag_name: tag[:name]), class: 'tag' do
        %strong
          = tag[:name]
        %small
          = tag[:count]
