#tag_artists.panel.center
  .panel_header
    %h3
      muffon
      |
      %i.fas.fa-tag
      = params[:name]

  .separator.sep_0.sep_light

  .panel_content

    %h4 Top artists:

    .separator.sep_10.sep_default

    .panel_content_wide
      - @artists.map do |artist|
        = render 'artist_card', artist: artist

    .text_center
      = paginate @artists
