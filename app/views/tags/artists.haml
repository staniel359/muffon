.card
  .card-body
    %h4
      %i.fas.fa-tag
      Tags

    %hr.my-3

    %h1.font-light.ml-4.mb-0
      = params[:tag_name]

    .separator.default.my-3

    %h5
      Artists:

    .separator.default.my-2

    - if @artists.any?
      - @artists.each do |artist|
        = render 'artist_card', artist: artist.decorate

      %nav
        %ul.pagination
          - if params[:page].to_i > 1
            %li.page-item
              = link_to_prev_page @artists, '< Prev', class: 'page-link'
          - if @artists.length == 21
            %li.page-item
              = link_to_next_page @artists, 'Next >', class: 'page-link'

    - else
      There are no artists.
