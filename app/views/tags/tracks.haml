#tag_tracks.panel.center
  .panel_header
    %h3
      muffon
      |
      = fa_icon 'tag'
      = params[:name]

  .separator.sep_0.sep_light

  .panel_content

    %h4 Top tracks:

    .separator.sep_10.sep_default

    %table.table.table-hover
      - @tracks.map do |track|
        = render 'track', track: track

    .text_center
      = paginate @tracks
