#library_artist_tracks_panel.panel.library_page.center
  = render 'library_artists/partials/panel_header'

  .separator.sep_0.sep_light

  #library_artist_tracks_panel_content.panel_content
    %h4
      = "Tracks (#{@artist.profile_tracks.count}):"

    .separator.sep_10.sep_default

    %table.table.table-hover
      = render partial: 'library_artists/partials/track', collection: @tracks
    .text_center
      = paginate @tracks