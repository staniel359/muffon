.album.album_170{class: ('mg_btm_20' unless params[:action] == 'album')}
	- if params[:action] == 'album'
		= link_to artist_album_path(name: album.artist.name, title: album.album.title) do
			= image_tag album.album.album_cover
			%h4
				%strong
					= album.album.title
			%h5
				%strong
					= album.artist.name
			%h5 on muffon
	- else
		= link_to library_artist_album_path(id: @profile.id, name: album.artist.name, title: album.album.album_title) do
			= image_tag album.album.album_cover
			%h4
				%strong
					= album.album.title
		%h5
			= link_to library_artist_album_plays_path(id: @profile.id, name: album.artist.name, title: album.album.album_title) do
				= pluralize(album.playcount, 'play')