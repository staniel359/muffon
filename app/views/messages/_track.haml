%tr
  %td.message_track{id: "track_#{track.id}", class: ('list_playing_now_track' if playing_now_track_id == track.id)}

    .media-left.mid_align.position-relative

      .list_play_button.no_padding.play_button

        - if playing_now_track_id == track.id

          = render 'shared/player/list_play_btn'

        - else

          = button_to play_path(artist: track.artist.artist_name, track: track.track_title), remote: true, class: 'btn btn-primary btn-sm play_btn', method: :get, onclick: 'loadTrack(this)' do
            %i.fas.fa-play

      = image_tag track.artist.artist_image, class: 'img_rnd img_30'

    .media-body.mid_align

      .track_options

        = render 'shared/tracks/dropdown', track: track

      .track_creds

        %h4.d-inline
          -# = link_to track.track.title, artist_track_path(name: track.artist.artist_name, title: track.track.track_title)
          = track.title

        %h5
          = link_to track.artist.name, artist_path(name: track.artist.artist_name)

    %iframe.mg_top_10{frameborder:'0', width: 480, height: 270, hidden: true}
