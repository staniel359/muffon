#conversation.panel.center
	.panel_header
		%h3
			= @title

	.separator.sep_0.sep_light

	#messages.panel_content

		%table.table.table-hover

			= render @messages

	%hr.sep_0

	#conversation_form.panel_content

		.media-left.mid_align
			= image_tag current_profile.avatar.url(:sm), class: 'img_rnd'

		.media-body.mid_align

			= form_for @message, remote: true do |f|
				= f.text_field :content, class: 'form-control', placeholder: 'Enter your message:'
				= f.hidden_field :profile_id, value: current_profile.id
				= hidden_field_tag :conversation_id, @conversation.id
				= hidden_field_tag :to, @conversation.other_member(current_profile.id).id
