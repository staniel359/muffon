- last_message = conversation.messages.last
- last_message_author = last_message.profile
- other_member = conversation.other_member(current_profile.id)

%tr.conversation
	%td
		= link_to conversation do
			.media-left
				- if other_member.present?

					= image_tag other_member.avatar.url(:sm), class: 'img_rnd'

				- else

					= image_tag 'avatar_default', class: 'img_rnd img_50'

			.media-body

				%h4#conversation_with.mg_btm_5

					- if other_member.present?

						= other_member.nickname

					- else

						Deleted Profile

				#conversation_last_msg.message_panel.mg_btm_10

					- if last_message.profile_id == current_profile.id

						.media-left
							= image_tag last_message_author.avatar.url(:sm), class: 'img_rnd'

					.media-body

						- if last_message.profile_id == current_profile.id

							%h5
								= last_message_author.nickname

						%h4.mg_btm_5
							= last_message.content

						%h6.text-muted
							= l last_message.created_at, format: "%e %b %Y, %H:%M"
