<% if @profile.errors.any? %>
  $('#registration-flash-msg').html("<%= j render 'partials/error_messages' %>");
<% else %>
  <% if @profile.lastfm_id.present? %>
    $('#additional-form').html("<%= j render 'partials/registrations/lastfm_import' %>");
  <% else %>
    $('#additional-form').html("<%= j render 'partials/registrations/additional_form' %>");
  <% end %>
  $('#signup-form').before($('#additional-form'))
  $('#signup-form').hide("slide", {direction: 'left'}, 500, function() {
    $('#signup-form').removeClass('d-block')
  })
  $('#additional-form').show("slide", {direction: 'right'}, 500);
  <% if @profile.lastfm_id.present? %>
    $('.ui-effects-placeholder').first().hide();
  <% else %>
    $('.ui-effects-placeholder').last().hide();
  <% end %>
<% end %>
