<% if @message.persisted? %>
  $('#conversation-messages').append(
    "<%= j render 'partials/conversations/messages/message', message: @message %>"
  )
  $('input[id="message_content"]').val('')
  scrollToConversationBottom();
  $('#message-modal .modal-content').html("<%= j render 'modals/messages/sent' %>");
<% end %>
