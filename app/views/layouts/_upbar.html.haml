#upbar
	%h3.up.text_center#logo= link_to 'muffon', root_path

	- if params[:controller] == 'muffon'

		- if params[:action] == 'home' && logged_in?
			.up#up_recs= link_to 'Home', root_path
		- if params[:action] == 'recommendations'
			.up#up_recs= link_to 'Recommendations', recommendations_path
		- if params[:action] == 'bookmarks'
			.up#up_bookmarks= link_to 'Bookmarks', bookmarks_path
		- if params[:action] == 'settings'
			.up#up_settings= link_to 'Settings', settings_path

	- if params[:controller] == 'profiles'

		- case params[:action]
		- when 'index'
			.up#up_index= link_to 'Profiles', profiles_path
		- when 'show'
			.up#up_show
				= link_to image_tag(@profile.avatar.url(:md)), @profile
				= link_to "#{@profile.nickname}'s profile", @profile

	- if params[:controller] == 'library'

		- case params[:action]
		- when 'show', 'artists', 'albums', 'tracks', 'plays'
			.up#up_library
				= link_to image_tag(@profile.avatar.url(:md)), @profile
				#up_link.inline= link_to "#{@profile.nickname}'s library", library_path
			- case params[:action]
			- when 'artists'
				.up#up_artists= link_to 'Artists', library_artists_path
			- when 'albums'
				.up#up_albums= link_to 'Albums', library_albums_path
			- when 'tracks'
				.up#up_tracks= link_to 'Tracks', library_tracks_path
			- when 'plays'
				.up#up_tracks= link_to 'Plays', library_plays_path

		- when 'artist', 'artist_albums', 'artist_plays', 'artist_tracks', 'album', 'album_plays', 'track_plays'
			.up#up_library= link_to image_tag(@profile.avatar.url(:md)), library_path
			.up#up_artists= link_to 'Artists', library_artists_path

			- case params[:action]
			- when 'artist', 'artist_albums', 'artist_plays', 'artist_tracks'
				.up#up_artist
					= image_tag ((@artist.artist.image && @artist.artist.image != '') ? @artist.artist.image : 'missing_artist.png')
					= link_to "#{@artist.artist.name}", library_artist_path
				- case params[:action]
				- when 'artist_albums'
					.up#up_artist_albums= link_to 'Albums', library_artist_albums_path
				- when 'artist_plays'
					.up#up_artist_plays= link_to 'Plays', library_artist_plays_path
				- when 'artist_tracks'
					.up#up_artist_tracks= link_to 'Tracks', library_artist_tracks_path
			- when 'album', 'album_plays'
				.up#up_artist
					= image_tag ((@album.album.artist.image && @album.album.artist.image != '') ? @album.album.artist.image : 'missing_artist.png')
					= link_to "#{@album.album.artist.name}", library_artist_path(artist_id: @album.profile_artist_id)
				.up#up_artist_albums= link_to 'Albums', library_artist_albums_path(artist_id: @album.profile_artist_id)
				.up#up_album
					= image_tag @album.album.cover
					= link_to "#{@album.album.title}", library_album_path
				- case params[:action]
				- when 'album_plays'
					.up#up_album_plays= link_to 'Plays', library_album_plays_path(album_id: @album.id)
			- when 'track_plays'
				.up#up_artist
					= image_tag @track.artist.image
					= link_to "#{@track.artist.name}", library_artist_path(artist_id: @track.profile_artist_id)
				.up#up_tracks= link_to 'Tracks', library_artist_tracks_path(artist_id: @track.profile_artist)
				.up#up_track= link_to @track.track.title, '#'
				.up#up_track_plays= link_to 'plays', library_track_plays_path

	- if params[:controller] == 'artists'

		- case params[:action]
		- when 'show'
			.up#up_artist
				= image_tag ((@artist_image && @artist_image != '') ? @artist_image : 'missing_artist.png')
				= link_to @artist['name'], artist_path
		- when 'albums'
			.up#up_artist
				= image_tag ((@artist_image && @artist_image != '') ? @artist_image : 'missing_artist.png')
				= link_to @artist_name, artist_path
			.up#up_artist_albums= link_to 'albums', artist_albums_path
		- when 'album'
			.up#up_artist
				= image_tag ((@artist_image && @artist_image != '') ? @artist_image : 'missing_artist.png')
				= link_to @album['artist'], artist_path
			.up#up_artist_albums= link_to 'albums', artist_albums_path
			.up#up_artist_album
				= image_tag (@album_cover != '' ? @album_cover : 'missing_album.png')
				= link_to @album['name'], artist_album_path
		- when 'tracks'
			.up#up_artist
				= image_tag ((@artist_image && @artist_image != '') ? @artist_image : 'missing_artist.png')
				= link_to @artist_name, artist_path
			.up#up_artist_tracks= link_to 'tracks', artist_tracks_path
		- when 'similar'
			.up#up_artist
				= image_tag ((@artist_image && @artist_image != '') ? @artist_image : 'missing_artist.png')
				= link_to @artist, artist_path
			.up#up_artist_similar= link_to 'similar artists', artist_similar_path

	- if params[:controller] == 'playlists'

		- case params[:action]
		- when 'index', 'show'
			.up#up_playlists
				= link_to image_tag(@profile.avatar.url(:md)), @profile
				#up_link.inline= link_to "#{@profile.nickname}'s playlists", playlists_path
			- case params[:action]
			- when 'show'
				.up#up_playlist= link_to @playlist.name, playlist_path

	- if params[:controller] == 'conversations'

		- case params[:action]
		- when 'index', 'show'
			.up#up_conversations
				= link_to 'Conversations', conversations_path
			- case params[:action]
			- when 'show'
				.up#up_conversation
					= link_to image_tag(other_profile_of(@conversation).avatar)
					= link_to other_profile_of(@conversation).nickname, @conversation

	- if params[:controller] == 'relationships'

		- case params[:action]
		- when 'follows', 'followers', 'following'
			.up#up_follows
				= link_to image_tag(@profile.avatar.url(:md)), @profile
				= link_to "#{@profile.nickname}'s follows", follows_path
			- case params[:action]
			- when 'followers'
				.up#up_followers= link_to 'Followers', followers_path
			- when 'following'
				.up#up_following= link_to 'Following', following_path