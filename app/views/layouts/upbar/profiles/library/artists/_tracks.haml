.up
  = link_to @profile do
    = image_tag @profile.avatar.url(:sm)

.up
  = link_to profiles_library_path do
    %h6
      %i.fas.fa-headphones

.up
  = link_to profiles_library_artists_path do
    %h6
      %i.fas.fa-user

.up.media
  = link_to profiles_library_artist_path do
    = image_tag @artist.image

    - if params[:action] == 'index'
      %h6
        = @artist.name

.up
  = link_to profiles_library_artists_tracks_path do
    %h6
      %i.fas.fa-music
      - unless params[:action].in?(%w[albums plays])
        Tracks

- unless params[:action] == 'index'
  .up
    = link_to profiles_library_artists_track_path do
      %h6
        = @track.title

  - if params[:action] == 'albums'
    .up
      = link_to profiles_library_artists_tracks_albums_path do
        %h6
          %i.fas.fa-dot-circle
          Albums

  - elsif params[:action] == 'plays'
    .up
      = link_to profiles_library_artists_tracks_plays_path do
        %h6
          %i.fas.fa-play
          Plays
