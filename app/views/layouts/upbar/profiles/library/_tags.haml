.up
  = link_to @profile do
    = image_tag @profile.avatar.url(:sm)

.up
  = link_to profiles_library_path do
    %h6
      %i.fas.fa-headphones

      - if params[:action] == 'index'
        Library

.up
  = link_to profiles_library_tags_path do
    %h6
      %i.fas.fa-tag
      Tags

- if params[:action] == 'show'
  .up
    = link_to profiles_library_tag_path do
      %h6
        = @tag.name
