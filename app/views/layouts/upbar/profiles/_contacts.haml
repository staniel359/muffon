- if params[:action] == 'contacts'

  .up
    .media-left
      = link_to image_tag(@profile.avatar.url(:sm)), profile_path
    .media-right
      = link_to "#{@profile.nickname}", profile_path

  .up
    .media-right
      = link_to "Contacts", profile_contacts_path

- elsif params[:action].in?(%w[followers following])

  .up
    .media-left
      = link_to image_tag(@profile.avatar.url(:sm)), profile_path

  .up
    .media-right
      = link_to "Contacts", profile_contacts_path

  - if params[:action] == 'followers'

    .up
      .media-right
        = link_to 'Followers', profile_followers_path

  - elsif params[:action] == 'following'

    .up
      .media-right
        = link_to 'Following', profile_following_path
