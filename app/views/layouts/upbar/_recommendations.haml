.up
  = link_to recommendations_path do
    %h6
      %i.fas.fa-volume-up
      Recommendations

- if params[:artist_name].present?
  .up
    - if @artist.present?
      = link_to recommendations_path(params.as_json.slice('artist_name')) do
        = image_tag @artist.image
        %h6
          = @artist.name
    - else
      %h6
        %i.fas.fa-question
        = params[:artist_name]

- if params[:tag_name].present?
  .up
    = link_to recommendations_path(params.as_json.slice('tag_name')) do
      %h6
        %i.fas.fa-tag
        = params[:tag_name]

- if params[:days].present?
  .up
    = link_to recommendations_path(params.as_json.slice('days')) do
      %h6
        %i.far.fa-calendar
        = params[:days]
