- if params[:action] == 'artists'

  %hr.sep_0

  .panel_content

    %h4
      Search results for
      %strong
        = "\"#{params[:q]}\""

  %hr.sep_0

.panel_content

  %h4
    %strong

      - if params[:action] == 'artists'

        Artists:

      - else

        = link_to 'Artists:', search_artists_path(q: params[:q])

  .separator.sep_10.sep_default

  - if @artists.present?

    .panel_content_wide

      - @artists.map do |artist|

        = render 'search/partials/artist', artist: artist

    - if params[:action] == 'index'

      .text_right
        = link_to 'View more...', search_artists_path(q: params[:q]), class: 'btn btn-primary btn-sm'

    - else

      .text_center
        .btn-group
          = link_to_prev_page @artists, '< Previous', class: 'btn btn-primary group_btn'
          = link_to_next_page @artists, 'Next >', class: 'btn btn-primary group_btn' unless @artists.length < 20

  - else

    %h5
      Nothing was found.
