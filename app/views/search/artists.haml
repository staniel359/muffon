#search.panel.center
  .panel_header
    %h3 Search for artist

  .separator.sep_0.sep_light

  .search_field.panel_content
    = form_tag search_artists_path, method: :get, remote: true, onsubmit: 'showLoading();' do
      = text_field_tag :q, nil, placeholder: 'Enter artist name...', class: 'form-control'

  .separator.sep_0.sep_light

  #search_results_content.relative

    .search_results.panel_content
      - if params[:q].present?
        = render 'artists'
