.d-flex.justify-content-between.align-items-center
  .media.align-items-center
    .mr-2
      = image_tag @album.cover, class: 'img-sm'
    .media-body
      %h4
        = link_to @album.title, artists_album_path

  .media.align-items-center
    .mr-2
      = image_tag @artist.image, class: 'img-xs rounded-circle'
    .media-body
      %h5.mb-0
        = link_to @artist.name, artist_path

%hr.my-3
