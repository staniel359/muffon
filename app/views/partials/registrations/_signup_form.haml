.card
  .card-body
    %h4 Sign up

    .separator.default.mt-3.mb-3

    #registration-flash-msg

    = form_for @profile, url: registration_path, html: { class: 'row no-gutters align-items-center' }, remote: true, multipart: true, authenticity_token: true do |f|

      = f.label :nickname, 'Nickname:', class: 'col-12 col-sm-3 mb-sm-2'
      .col-12.col-sm-9
        = f.text_field :nickname, class: 'input-transp mb-2', required: true

      = f.label :email, 'Email:', class: 'col-12 col-sm-3 mb-sm-2'
      .col-12.col-sm-9
        = f.email_field :email, class: 'input-transp mb-2', required: true

      = f.label :password, 'Password:', class: 'col-12 col-sm-3 mb-sm-2'
      .col-12.col-sm-9
        = f.password_field :password, class: 'input-transp mb-2', required: true

      = f.label :password_confirmation, 'Confirm password:', class: 'col-12 col-sm-3 mb-sm-3'
      .col-12.col-sm-9
        = f.password_field :password_confirmation, class: 'input-transp mb-3', required: true

      = submit_tag 'Sign up', form: 'new_profile', class: 'btn btn-light btn-block'

    %h6.text-center.mt-2.mb-0
      = button_to login_path, method: :get, remote: true, class: 'btn btn-link text-white' do
        = t('registrations.login')
