- if @artists.any?
  .row
    - @artists.each do |artist|
      .col-6.col-sm-4.col-lg-3.mb-2
        = render 'partials/profiles/library/instances/artist', artist: artist
  .text-right
    = link_to 'View more...', profiles_library_artists_path(scope: params[:scope]), class: 'btn btn-primary btn-sm'
- else
  There are no artists.
