.mr-3
  = image_tag @profile.avatar.url(:md), id: 'profile-page-avatar', class: 'rounded-circle'
  - if other_profile?(@profile)
    .mt-2
      #follow-button.mb-1{ id: @profile.id }
        = render 'partials/relationships/follow_button', profile: @profile
      = button_to messages_open_modal_path(to: profile.nickname), class: 'btn btn-sm btn-primary', method: :get, remote: true do
        %i.fas.fa-envelope
        Write a message
    = render 'modals/message'
