%tr
  %td
    .media.align-items-center
      #playlist-add-artist-btn.mr-2{ id: artist.artist_id }
        = render 'partials/profiles/playlists/artist/add_btn', artist: artist
      .media-body.media.align-items-center
        .mr-2
          = image_tag artist.image, class: 'rounded-circle img-xs'
        .media-body.d-flex.justify-content-between.align-items-center
          #artist-data
            %h5.mb-1
              = link_to artist.name, profiles_library_artist_path(artist_name: artist.name)

          #artist-options
            #show-artist-tracks-btn
              = button_to profiles_playlists_search_show_artist_tracks_path(playlist_id: params[:playlist_id], profile_artist_id: artist.id), class: 'tag', method: :get, remote: true do
                %strong
                  = "Tracks (#{artist.tracks_count})"
                %i.fas.fa-caret-down
            #show-artist-albums-btn
              = button_to profiles_playlists_search_show_artist_albums_path(playlist_id: params[:playlist_id], profile_artist_id: artist.id), class: 'tag', method: :get, remote: true do
                %strong
                  = "Albums (#{artist.albums_count})"
                %i.fas.fa-caret-down

    #search-profile-artist-tracks-albums.ml-4{ id: artist.id }
