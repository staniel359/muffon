.up
  .media-left
    = link_to image_tag(@profile.avatar.url(:sm)), profile_path
  .media-right
    = link_to "#{@profile.nickname}", profile_path

.up
  .media-right
    %i.fas.fa-list-ul
    = link_to profiles_playlists_path do
      Playlists

- if params[:action].in?(%w[show edit])

  .up
    .media-right
      = link_to @playlist.name, profiles_playlist_path

  - if params[:action] == 'edit'

    .up
      .media-right
        %i.fas.fa-pencil-alt
        Edit
