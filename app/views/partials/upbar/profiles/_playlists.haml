.up.media
  = image_tag @profile.avatar.url(:sm)
  .media-body
    = link_to @profile.nickname, @profile

.up.media
  .media-body
    = link_to profiles_playlists_path do
      %i.fas.fa-list-ul
      Playlists

- if params[:action] == 'show'
  .up.media
    .media-body
      = link_to @playlist.name, profiles_playlist_path

