.up.media
  = link_to @profile do
    = image_tag @profile.avatar.url(:sm)

.up.media
  .media-body
    = link_to profiles_library_path do
      %i.fas.fa-headphones

.up.media
  .media-body
    = link_to profiles_library_artists_path do
      %i.fas.fa-user

.up.media
  = image_tag @artist.image
  .media-body
    = link_to @artist.name, profiles_library_artist_path

.up.media
  .media-body
    = link_to profiles_library_artists_plays_path do
      %i.fas.fa-play
      Plays
