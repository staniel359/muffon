%tr
  %td.search_entry

    .media-left.mid_align

      .playlist_add_button
        = button_to playlist_add_profile_artist_path(profile_artist_id: artist.id), class: 'btn btn-sm btn-primary playlist_add_btn', method: :post, remote: true do
          %i.fas.fa-angle-double-left

      = image_tag artist.artist_image, class: 'img_rnd img_50'

    .media-body.mid_align

      %h4.mg_btm_5.d-inline
        = link_to artist.name, library_artist_path(id: current_profile.id, name: artist.artist_name)

      = button_to playlist_search_artist_tracks_path(profile_artist_id: artist.id), method: :get, class: 'btn btn-primary btn-sm', remote: true do
        = "Tracks (#{artist.tracks_count})"
        .caret

    .search_artist_tracks.mg_top_5#search_artist_tracks{id: artist.id}
