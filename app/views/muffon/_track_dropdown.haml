.dropdown.track_dropdown

  .dropdown-toggle{data: {toggle: 'dropdown'}}
    = button_tag class: 'inv_btn_no_hover' do
      %h4
        %i.fas.fa-ellipsis-v

  .dropdown-menu.track_actions_dropdown

    - if logged_in?

      = button_to watch_on_youtube_path(track_id: track.id), class: 'btn btn-primary btn-sm play_btn btn_group_first', data: {toggle: 'tooltip', placement: 'left'}, title: 'Watch on YouTube', onclick: 'closeDropdown();', method: :get, remote: true do
        %i.fab.fa-youtube

      = button_to track_message_modal_path(track_id: track.id), class: 'btn btn-primary btn-sm play_btn btn_group_mid', data: {toggle: 'tooltip', placement: 'left'}, title: 'Send in message', method: :get, remote: true do
        %i.fas.fa-comments

      = button_to track_playlists_modal_path(track_id: track.id), class: 'btn btn-primary btn-sm play_btn btn_group_mid', data: {toggle: 'tooltip', placement: 'left'}, title: 'Add to playlist', method: :get, remote: true do
        %i.fas.fa-list-alt

      = button_to send_to_queue_path(track_ids: [track.id]), class: 'btn btn-primary btn-sm play_btn btn_group_mid', data: {toggle: 'tooltip', placement: 'left'}, title: 'Send to queue', onclick: 'closeDropdown();', method: :get, remote: true do
        %i.fas.fa-arrow-right

      - if params[:controller].downcase.include?('playlist')

        = button_to playlist_delete_track_path(track_id: track.id), class: 'btn btn-primary btn-sm play_btn btn_group_last', data: {toggle: 'tooltip', placement: 'left'}, title: 'Delete from playlist', onclick: 'closeDropdown();', method: :delete, remote: true do
          %i.fas.fa-times

      - else

        = button_tag class: 'btn btn-primary btn-sm play_btn btn_group_last', data: {toggle: 'tooltip', placement: 'left'}, title: 'Delete from library', onclick: 'closeDropdown();', method: :get, remote: true do
          %i.fas.fa-times

    - else

      = button_to watch_on_youtube_path(track_id: track.id), class: 'btn btn-primary btn-sm play_btn', data: {toggle: 'tooltip', placement: 'left'}, title: 'Watch on YouTube', onclick: 'closeDropdown();', method: :get, remote: true do
        %i.fab.fa-youtube
