#settings.panel.panel-default.center
	.panel_header_sm
		%h3 Settings
	.panel_content
		#settings_panel_left.inline
			#settings_edit_form
				%h4.settings_header_sm Edit profile
				= render 'profiles/form'
			%hr
			#settings_password_form
				%h4.settings_header_sm Change password
				= form_for @profile, remote: true do |f|
					= f.password_field :password, class: 'form-control', placeholder: 'Password:'
					= f.password_field :password_confirmation, class: 'form-control', placeholder: 'Confirm password:'
					.submit_btn.text_right= f.submit 'Change password', class: 'btn btn-primary'
		#setting_panel_right.inline.top_align
			#settings_privacy 
				%h4.settings_header_sm Privacy
			%hr
			#settings_lastfm_sync
				%h4.settings_header_sm Synchronize with Last.fm
				- if @profile.lastfm_id
					- if !@profile.plays.any?
						= button_to 'Import you library', import_plays_path(do: 'import'), method: :get, class: 'btn btn-primary', remote: true if current_profile.lastfm_id
					- else
						= button_to 'Refresh your listens', import_plays_path(do: 'refresh'), method: :get, class: 'btn btn-primary', remote: true if current_profile.lastfm_id
				- else
					= link_to 'Connect your Last.fm account', '/auth/lastfm', class: 'btn btn-danger'
			%hr
			#settings_delete_account_btn
				%h4.settings_header_sm Delete account
				= link_to 'Delete account', @profile, method: :delete, class: 'btn btn-danger', data: {confirm: 'Warning! All data from your account will be destroyed. 	Proceed?'}