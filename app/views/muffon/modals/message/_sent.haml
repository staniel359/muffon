#message_sent.panel_content

  #modal_track.mg_btm_10
    - Track.where(id: params['message'][:track_ids]).map do |track|
      = render 'muffon/modals/track', track: track

  %h5.mg_btm_10
    has been sent to:

  .media-left.mid_align
    = image_tag @recipient.avatar.url(:xs), class: 'img_rnd'
  .media-body.mid_align
    %h4
      = @recipient.nickname

  = link_to 'Go to conversation', conversation_path(@conversation), class: 'btn btn-primary'
