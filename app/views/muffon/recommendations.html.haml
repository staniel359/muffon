.recommendations_page.center.panel.panel-default
	.panel_header
		%h3= link_to "Your recommendations:", recommendations_path
		.dropdown.pull-right
			.btn.dropdown_btn.dropdown-toggle{data: {toggle: 'dropdown'}} 
				= fa_icon 'filter'
				Filter by:
			%ul.dropdown-menu.dropdown-menu-right
				%li
					= form_tag recommendations_path, method: :get do
						= text_field_tag :artist, params[:artist], placeholder: 'Artist:', class: 'form-control'
						= submit_tag 'Search', name: nil, style: 'display: none'
				%li
					= form_tag recommendations_path, method: :get do
						= text_field_tag :tag, params[:tag], placeholder: 'Tag:', class: 'form-control'
						= submit_tag 'Search', name: nil, style: 'display: none'
				%li
					= form_tag recommendations_path, method: :get do
						= text_field_tag :date, params[:date], placeholder: 'Date in days:', class: 'form-control'
						= submit_tag 'Search', name: nil, style: 'display: none'
	.recommendations.panel_content
		- if @recs
			- @recs.map do |r|
				.rec_wrap
					.panel.panel-default.recommendation#recommendation{id: r.id}
						.media-left.recommendation_artist_tags
							.recommendation_artist
								= render 'artists/actions', a_id: r.id, artist_name: r.artist_name, image: r.image
								= link_to artist_path(r.artist_name) do
									.artist_image
										= image_tag ((r.image != '') ? r.image : 'missing_artist.png')
									%h4
										%strong= r.artist_name
							.recommendation_tags
								- r.tags.first(5).map do |t|
									- tag = Tag.find(t).name
									.label.label-primary= link_to tag, recommendations_path(tag: tag)
						.media-body.recommendation_similars
							%h5.rec_header Similar to:
							.recommendation_similars_artists
								- r.profile_artists.first(5).map do |a|
									.recommendation_similars_artist
										.artist_image= image_tag ((@profile.profile_artists.find(a).artist.image != '') ? @profile.profile_artists.find(a).artist.image : 'missing_artist.png')
										%h5= link_to @profile.profile_artists.find(a).artist.name, library_artist_path(id: @profile, artist_id: a)
								= link_to "and #{pluralize((r.profile_artists.length - 5), 'more artist')}...", '#' if r.profile_artists.length > 5
			%br
			= will_paginate @recs if @recs.count > 20