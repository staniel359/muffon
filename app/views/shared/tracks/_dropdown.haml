.dropdown
  = button_tag class: 'btn-transp dropdown-toggle px-2 py-1', data: { toggle: 'dropdown' } do
    %h5.mb-0
      %i.fas.fa-ellipsis-v.text-white
  .dropdown-menu.dropdown-menu-right
    .dropdown-item
      = button_tag class: 'btn-transp' do
        %i.fab.fa-youtube.mr-1
        = link_to 'Watch on YouTube', player_watch_on_youtube_path(track_id: track.id), remote: true

    - if logged_in?
      .dropdown-item
        = button_tag class: 'btn-transp' do
          %i.fas.fa-comments.mr-1
          = link_to 'Send in message', '#', remote: true
      .dropdown-item
        = button_tag class: 'btn-transp' do
          %i.fas.fa-arrow-right.mr-1
          = link_to 'Send to queue', player_queue_send_path(track_ids: [track.id]), remote: true

      - if params[:controller].downcase.include?('library')
        .dropdown-divider

        .dropdown-item
          = button_tag class: 'btn-transp' do
            %i.fas.fa-times.mr-1.text-danger
            = link_to 'Delete from library', '#', remote: true
