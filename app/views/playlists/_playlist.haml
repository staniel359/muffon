%tr.playlist#playlist{id: playlist.id}
  %td
    %h3.inline
      = link_to playlist.name, playlist_path(playlist_name: playlist.name)
    - if current_profile?(@profile)
      %h5.inline.pull-right
        = button_to playlist_path(playlist_name: playlist.name), method: :delete, class: 'btn btn-primary btn-sm', remote: true do
          = fa_icon 'times'
          Delete
    %h5.text-muted
      = playlist.playlist_tracks.count
      tracks