$('audio').attr('src', '')

<% if @track.present? %>
  $("*#track_<%= @track.id %>").removeClass('list_playing_now_track')
  $("*#track_<%= @track.id %> > i").removeClass('fa-pause').addClass('fa-play')
  $("*#track_<%= @track.id %> > .list_play_button").html("<%= j render 'player/get_track_button', track: @track %>")
  $("*#track_<%= @track.id %> .media-left > .list_play_button").html("<%= j render 'player/get_track_button', track: @track %>")
<% end %>

$("#profile_page_playing_now_track_<%= current_profile.id %>").html("<%= j render 'profiles/playing_now_track'%>")
$('#enqueued_tracks').html("<%= j render 'player/enqueued_tracks' %>")

hidePlayer();
hidePlayingNow();
