- if playing_now_track.present?

  .media-left.mid_align
    = image_tag playing_now_track.artist.artist_image, class: 'img_rnd img_50'
  .media-body.mid_align
    .pull-right.mg_top_10
      = button_to delete_playing_now_path, class: 'inv_btn', method: :get, remote: true do
        = fa_icon 'times'
    %h4
      %strong
        = link_to CGI.unescape(playing_now_track.title), '#'
    %h5
      = link_to CGI.unescape(playing_now_track.artist.name), artist_path(name: CGI.unescape(playing_now_track.artist.name))
- else

  %h5 Nothing is playing now.
