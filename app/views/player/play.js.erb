<% if @audio_link.present? %>
  $('audio').attr('src', "<%= @audio_link %>").trigger('play')

  <% if @previous_track.present?%>
    $("*#track_<%= @previous_track.id %>").removeClass('list_playing_now_track')
    $("*#track_<%= @previous_track.id %> > i").removeClass('fa-pause').addClass('fa-play')
    $("*#track_<%= @previous_track.id %> > .list_play_button").html("<%= j render 'player/get_track_button', track: @previous_track %>")
    $("*#track_<%= @previous_track.id %> .media-left > .list_play_button").html("<%= j render 'player/get_track_button', track: @previous_track %>")
  <% end %>

  $("*#track_<%= @track.id %>").addClass('list_playing_now_track')
  $("*#track_<%= @track.id %> > i").removeClass('fa-play').addClass('fa-pause')
  $("*#track_<%= @track.id %> > .list_play_button").html("<%= j render 'player/list_play_button', track: @track %>")
  $("*#track_<%= @track.id %> > .media-left > .list_play_button").html("<%= j render 'player/list_play_button', track: @track %>")

  $('#player_play_btn > i').removeClass('fa-play').addClass('fa-pause')

  $('#playing_now_track').html("<%= j render 'player/playing_now_track' %>")
  $('#player_playing_now_track').html("<%= j render 'player/playing_now_track_sm' %>")

  $('#enqueued_tracks').html("<%= j render 'player/enqueued_tracks' %>")
  $('#profile_page_playing_now').html("<%= j render 'profiles/playing_now_track'%>")

  $('#change_track_actions').hide().html("<%= j render 'player/change_track' %>").show('slide', {direction:'left'}, 400)
<% end %>

$('#player').show('slide', {direction:'down'}, 400)
$('#footer').animate({'height': '205px'}, 400)
$('#progress_bars').animate({'bottom': '65px'}, 400)

if ($("#playing_now").css("display") == 'block') {
  $('.center').css('margin-left','80px')
}