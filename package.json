{
  "name": "muffon",
  "version": "2.4.0",
  "description": "Advanced multi-source music streaming + discovery client",
  "homepage": "https://muffon.netlify.app",
  "repository": "https://github.com/staniel359/muffon",
  "license": "AGPL-3.0",
  "author": {
    "name": "Aleksey Shpakovsky",
    "email": "staniel359@gmail.com",
    "url": "https://github.com/staniel359"
  },
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start:vue": "vite",
    "start:electron": "electron .",
    "lint": "eslint",
    "build:vue": "vite build",
    "build:electron": "electron-builder --dir",
    "build": "pnpm build:vue && pnpm build:electron",
    "package:electron": "electron-builder",
    "package": "pnpm build:vue && pnpm package:electron",
    "release:electron": "pnpm package:electron --publish always",
    "release": "pnpm build:vue && pnpm release:electron",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "electron-dl": "^4.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "emoji-picker-element": "^1.29.0",
    "emoji-picker-element-data": "^1.8.0",
    "i18n": "^0.15.3",
    "music-metadata": "^11.12.1",
    "sanitize-html": "^2.17.1",
    "uint8array-extras": "^1.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-inject": "^5.0.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "axios": "^1.13.6",
    "change-case": "^5.4.4",
    "crypto-js": "^4.2.0",
    "deepmerge": "^4.3.1",
    "electron": "^40.6.1",
    "electron-builder": "26.8.1",
    "eslint": "^10.0.2",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "fomantic-ui": "^2.9.4",
    "globals": "^17.3.0",
    "hotkeys-js": "^4.0.2",
    "i18n-iso-countries": "^7.14.0",
    "jquery": "^4.0.0",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "slick-carousel": "^1.8.1",
    "vite": "^7.3.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-eslint": "^1.8.1",
    "vue": "^3.5.29",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "electron-winstaller",
      "es5-ext",
      "esbuild",
      "less",
      "register-scheme"
    ]
  }
}
